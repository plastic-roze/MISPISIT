@startuml
!theme plain
skinparam backgroundColor #FEFEFE
skinparam componentStyle rectangle

Title IDEF0 - Контекстная диаграмма системы

skinparam rectangleBorderColor #2980B9
skinparam rectangleBorderThickness 2

rectangle "Система сборки\nкомпьютеров на заказ" as System #3498DB {
}

rectangle "Учетные данные" as Input1 #E74C3C
rectangle "Параметры компонентов" as Input2 #E74C3C
rectangle "Заказы клиентов" as Input3 #E74C3C

rectangle "Отчеты о заказах" as Output1 #2ECC71
rectangle "Статусы сборок" as Output2 #2ECC71
rectangle "Журналы аудита" as Output3 #2ECC71

rectangle "Бизнес-правила" as Control #F39C12

rectangle "TCP-сервер" as Mech1 #9B59B6
rectangle "PostgreSQL" as Mech2 #9B59B6

Input1 -[#E74C3C,thickness=2]-> System : Вход
Input2 -[#E74C3C,thickness=2]-> System : Вход
Input3 -[#E74C3C,thickness=2]-> System : Вход

System -[#2ECC71,thickness=2]-> Output1 : Выход
System -[#2ECC71,thickness=2]-> Output2 : Выход
System -[#2ECC71,thickness=2]-> Output3 : Выход

Control -[#F39C12,thickness=2]-> System : Управление

Mech1 -[#9B59B6,thickness=2]-> System : Механизм
Mech2 -[#9B59B6,thickness=2]-> System : Механизм

legend right
  |= Цвет |= Значение |
  | <#E74C3C> | Входы |
  | <#F39C12> | Управление |
  | <#2ECC71> | Выходы |
  | <#9B59B6> | Механизмы |
endlegend

@enduml
