@startuml
!theme plain
skinparam backgroundColor #FEFEFE

Title UML Class Diagram

skinparam classAttributeIconSize 0

package "Repository Pattern" as RepoPackage {

    interface IComponentRepository <<interface>> {
        +create(data: dict): int
        +get_by_id(id: int): dict
        +get_all(filters: dict): list
        +update(id: int, data: dict): bool
        +delete(id: int): bool
    }

    interface IOrderRepository <<interface>> {
        +create(data: dict): int
        +get_by_id(id: int): dict
        +get_all(filters: dict): list
        +update_status(id: int, status: str): bool
        +delete(id: int): bool
    }

    interface IUserRepository <<interface>> {
        +create(data: dict): int
        +get_by_id(id: int): dict
        +get_all(): list
        +delete(id: int): bool
    }

    class OrmComponentRepository {
        -db: Session
        +create(data): int
        +get_by_id(id): dict
        +get_all(filters): list
        +update(id, data): bool
        +delete(id): bool
    }

    class SqlComponentRepository {
        -_get_connection(): Connection
        +create(data): int
        +get_by_id(id): dict
        +get_all(filters): list
        +update(id, data): bool
        +delete(id): bool
    }

    class OrmOrderRepository {
        -db: Session
        +create(data): int
        +get_by_id(id): dict
        +get_all(filters): list
        +update_status(id, status): bool
        +delete(id): bool
    }

    class SqlOrderRepository {
        -_get_connection(): Connection
        +create(data): int
        +get_by_id(id): dict
        +get_all(filters): list
        +update_status(id, status): bool
        +delete(id): bool
    }

    class OrmUserRepository {
        -db: Session
        +create(data): int
        +get_by_id(id): dict
        +get_all(): list
        +delete(id): bool
    }

    class SqlUserRepository {
        -_get_connection(): Connection
        +create(data): int
        +get_by_id(id): dict
        +get_all(): list
        +delete(id): bool
    }

    class RepositoryFactory {
        +create_component_repository(use_orm): IComponentRepository
        +create_order_repository(use_orm): IOrderRepository
        +create_user_repository(use_orm): IUserRepository
    }
}

package "Authentication" as AuthPackage {
    class AuthService {
        +hash_password(password: str): str
        +verify_password(password: str, hashed: str): bool
        +authenticate(username: str, password: str): dict
        +register_user(username: str, password: str, role: str): int
    }
}

package "Server" as ServerPackage {
    class Server {
        -host: str
        -port: int
        -server_socket: socket
        -running: bool
        +start()
        +handle_client(socket, address)
        +process_request(request: dict, session_id: str): dict
        +stop()
    }

    class Database {
        +get_raw_connection(): Connection
        +get_db_session(): Session
    }
}

package "ORM Models" as ModelsPackage {
    class Component {
        +component_id: int
        +category_id: int
        +component_name: str
        +brand: str
        +model: str
        +price: Decimal
        +selling_price: Decimal
        +quantity_in_stock: int
    }

    class Order {
        +order_id: int
        +client_id: int
        +build_id: int
        +order_type: str
        +status: str
        +total_price: Decimal
        +order_date: datetime
    }

    class User {
        +user_id: int
        +username: str
        +password_hash: str
        +role: str
        +created_at: datetime
    }

    class Finance {
        +record_id: int
        +order_id: int
        +record_type: str
        +amount: Decimal
        +record_date: datetime
    }
}

' Inheritance
IComponentRepository <|.. OrmComponentRepository
IComponentRepository <|.. SqlComponentRepository
IOrderRepository <|.. OrmOrderRepository
IOrderRepository <|.. SqlOrderRepository
IUserRepository <|.. OrmUserRepository
IUserRepository <|.. SqlUserRepository

' Factory usage
RepositoryFactory ..> OrmComponentRepository : creates
RepositoryFactory ..> SqlComponentRepository : creates
RepositoryFactory ..> OrmOrderRepository : creates
RepositoryFactory ..> SqlOrderRepository : creates
RepositoryFactory ..> OrmUserRepository : creates
RepositoryFactory ..> SqlUserRepository : creates

' Server dependencies
Server --> AuthService : uses
Server --> RepositoryFactory : uses
Server --> Database : uses

' ORM relationships
OrmComponentRepository --> Component : manages
OrmOrderRepository --> Order : manages
OrmOrderRepository --> Finance : creates
OrmUserRepository --> User : manages

@enduml
