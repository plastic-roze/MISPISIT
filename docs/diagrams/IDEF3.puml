@startuml
!theme plain
skinparam backgroundColor #FEFEFE

Title IDEF3 - Сценарий процесса

start

:Запуск клиентского
приложения;

:Авторизация
пользователя;

if (Авторизация
успешна?) then (да)
  :Проверка
прав доступа;

  if (Роль?) then (admin)
    :Управление
пользователями;
  else (operator/manager)
  endif

  :Выбор типа
заказа;

  if (Тип заказа?) then (catalog)
    :Оформление
каталогового заказа;
  else (custom)
    :Оформление
кастомного заказа;
  endif

  :Валидация
данных;

  if (Валидация
пройдена?) then (да)
    :Сохранение
в БД;
    :Обновление
статуса заказа;
    :Формирование
финансовой записи;
    stop
  else (нет)
    :Вывод ошибки;
    stop
  endif

else (нет)
  :Вывод ошибки
авторизации;
  stop
endif

@enduml
