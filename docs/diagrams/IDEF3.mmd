%% Mermaid flowchart for process scenario (IDEF3)
flowchart TD
    Start([Start])
    A["Запуск клиентского приложения"]
    B["Авторизация пользователя"]
    C{"Авторизация успешна?"}
    D["Проверка прав доступа"]
    E{"Роль?"}
    E_admin["Управление пользователями (admin)"]
    E_other["Операции оператора/менеджера"]
    F["Выбор типа заказа"]
    G{"Тип заказа?"}
    G_catalog["Оформление каталогового заказа"]
    G_custom["Оформление кастомного заказа"]
    H["Валидация данных"]
    I{"Валидация пройдена?"}
    J["Сохранение в БД\nОбновление статуса\nФормирование финансовой записи"]
    K["Вывод ошибки"]
    End([Stop])

    Start --> A --> B --> C
    C -- yes --> D --> E
    E -- admin --> E_admin --> F
    E -- operator/manager --> E_other --> F
    F --> G
    G -- catalog --> G_catalog --> H
    G -- custom --> G_custom --> H
    H --> I
    I -- yes --> J --> End
    I -- no --> K --> End
    C -- no --> K --> End
