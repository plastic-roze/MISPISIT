@startuml
!theme plain
skinparam backgroundColor #FEFEFE

Title DFD - Потоки данных

left to right direction

rectangle "Внешние сущности" as ExternalEntities {
    rectangle "Оператор" as Operator #E74C3C
    rectangle "Администратор" as Admin #E74C3C
    rectangle "Клиент" as Client #E74C3C
}

rectangle "Процессы" as Processes {
    rectangle "1.0
Авторизация" as P1 #3498DB
    rectangle "2.0
Маршрутизация" as P2 #3498DB
    rectangle "3.0
Обработка заказов" as P3 #3498DB
    rectangle "4.0
Управление компонентами" as P4 #3498DB
    rectangle "5.0
Финансовый учет" as P5 #3498DB
}

rectangle "Хранилища данных" as DataStores {
    database "Users" as DS1 #2ECC71
    database "Components" as DS2 #2ECC71
    database "Orders" as DS3 #2ECC71
    database "Finances" as DS4 #2ECC71
}

' External to Processes
Operator --> P1 : Учетные данные
Operator --> P2 : Запросы
Admin --> P2 : Запросы
Client --> P3 : Заказ

' Processes to Data Stores
P1 --> DS1 : Чтение/запись
P2 --> DS2 : Чтение/запись
P2 --> DS3 : Чтение/запись
P3 --> DS3 : Чтение/запись
P3 --> P5 : Данные заказа
P4 --> DS2 : Чтение/запись
P5 --> DS4 : Запись

' Data Stores to Processes
DS1 --> P2 : Данные пользователей
DS2 --> P3 : Комплектующие
DS3 --> P5 : Заказы

' Outputs
P2 --> Operator : Результат
P2 --> Admin : Результат
P3 --> Client : Подтверждение
P5 --> Admin : Финансовый отчет

@enduml
